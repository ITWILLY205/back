generator client {
  provider = "prisma-client-js"
  output   = "./node_modules/@prisma/client"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  password      String
  role          String
  full_name     String?
  email         String?
  created_at    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacher       Teacher?
  student       Student?
  disciplineIncidents DisciplineIncident[] @relation("ReportedBy")
  notifications Notification[] @relation("Sender")
  receivedNotifications Notification[] @relation("Recipient")

  @@map("users")
}

model AcademicYear {
  id      Int      @id @default(autoincrement())
  name    String
  status  String   @default("Active")
  terms   Term[]

  @@map("academic_years")
}

model Term {
  id          Int      @id @default(autoincrement())
  year_id     Int
  name        String
  start_date  DateTime?
  end_date    DateTime?

  year        AcademicYear @relation(fields: [year_id], references: [id], onDelete: Cascade)
  marks       Mark[]
  teacherAssignments TeacherAssignment[]

  @@map("terms")
}

model Class {
  id      Int      @id @default(autoincrement())
  name    String
  streams Stream[]
  students Student[]

  @@map("classes")
}

model Stream {
  id        Int      @id @default(autoincrement())
  class_id  Int
  name      String

  class     Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  students  Student[]
  teacherAssignments TeacherAssignment[]

  @@map("streams")
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?  @unique
  category  String   @default("CORE")

  marks     Mark[]
  teacherAssignments TeacherAssignment[]

  @@map("subjects")
}

model Teacher {
  id              Int      @id @default(autoincrement())
  user_id         Int      @unique
  staff_id        String   @unique
  specialization  String?

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignments     TeacherAssignment[]

  @@map("teachers")
}

model TeacherAssignment {
  id          Int      @id @default(autoincrement())
  teacher_id  Int
  subject_id  Int
  stream_id   Int
  term_id     Int

  teacher     Teacher  @relation(fields: [teacher_id], references: [id])
  subject     Subject  @relation(fields: [subject_id], references: [id])
  stream      Stream   @relation(fields: [stream_id], references: [id])
  term        Term     @relation(fields: [term_id], references: [id])

  @@map("teacher_assignments")
}

model Student {
  id            Int      @id @default(autoincrement())
  user_id       Int      @unique
  student_id    String   @unique
  class_id      Int?
  stream_id     Int?
  parent_name   String?
  parent_phone  String?

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  class         Class?   @relation(fields: [class_id], references: [id])
  stream        Stream?  @relation(fields: [stream_id], references: [id])
  marks         Mark[]
  attendance    Attendance[]
  disciplineIncidents DisciplineIncident[]

  @@map("students")
}

model Mark {
  id            Int      @id @default(autoincrement())
  student_id    Int
  subject_id    Int
  term_id       Int
  cat_score     Int      @default(0)
  exam_score    Int      @default(0)
  total_score   Int      @default(0)
  grade         String?

  student       Student  @relation(fields: [student_id], references: [id])
  subject       Subject  @relation(fields: [subject_id], references: [id])
  term          Term     @relation(fields: [term_id], references: [id])

  @@unique([student_id, subject_id, term_id])
  @@map("marks")
}

model Attendance {
  id            Int      @id @default(autoincrement())
  student_id    Int
  date          DateTime
  status        String   @default("Present")

  student       Student  @relation(fields: [student_id], references: [id])

  @@unique([student_id, date])
  @@map("attendance")
}

model DisciplineIncident {
  id              Int      @id @default(autoincrement())
  student_id      Int
  reported_by     Int
  description     String?
  action_taken    String?
  punishment_marks Int     @default(0)
  date            DateTime?

  student         Student  @relation(fields: [student_id], references: [id])
  reporter        User     @relation("ReportedBy", fields: [reported_by], references: [id])

  @@map("discipline_incidents")
}

model Notification {
  id              Int      @id @default(autoincrement())
  sender_id       Int?
  recipient_id    Int?
  recipient_role  String?
  title           String?
  message         String
  type            String   @default("general")
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  sender          User?    @relation("Sender", fields: [sender_id], references: [id])
  recipient       User?    @relation("Recipient", fields: [recipient_id], references: [id])

  @@map("notifications")
}
